# ── Backend ──────────────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=sombraia-hackathon
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json
# "development" desactiva la verificación de token Firebase (útil en local)
ENV=development

# ── React Native (no van al backend — configurar en el proyecto móvil) ───────
# MAPS_API_KEY=           ← GCP Console → APIs & Services → Credentials
#                            Restringir al bundle ID de la app
#
# google-services.json    ← Firebase Console → Project Settings → Android
# GoogleService-Info.plist← Firebase Console → Project Settings → iOS
#
# El Web Client ID y el API Key de Firebase ya vienen dentro de esos archivos.
# No hace falta configurarlos manualmente.
